        <mxCell id="db" value="SQLite Database&#10;(db.sqlite3)" style="shape=cylinder3;whiteSpace=wrap;html=1;fontSize=13;fontStyle=1;fillColor=#E2E2E2;strokeColor=#595959;align=center;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="350.0" y="640" width="200" height="80" as="geometry" />
