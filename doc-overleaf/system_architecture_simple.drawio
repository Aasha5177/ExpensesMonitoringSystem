        <mxCell id="forms" value="Forms Layer — Input Validation&#10;(RegisterForm, ExpenseForm, BudgetForm, ...)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;align=center;verticalAlign=middle;fillColor=#E1D5E7;strokeColor=#9673A6;fontColor=#4A2E56;" vertex="1" parent="1">
          <mxGeometry x="260" y="420" width="380" height="65" as="geometry" />
