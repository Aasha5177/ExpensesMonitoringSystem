        <mxCell id="e1" value="HTTP Request /&#10;Response" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=11;endArrow=block;strokeColor=#595959;" edge="1" parent="1" source="client" target="presentation">
