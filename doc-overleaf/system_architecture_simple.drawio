        <mxCell id="app" value="Application Layer (Controllers)&#10;&#10;Dashboard · Expenses · Budget ·&#10;Family Groups · Reports · Profile" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;align=center;verticalAlign=middle;fillColor=#D5E8D4;strokeColor=#3D8A3D;fontColor=#1F4A1F;" vertex="1" parent="1">
          <mxGeometry x="260" y="250" width="380" height="130" as="geometry" />
