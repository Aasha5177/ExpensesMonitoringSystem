<?xml version='1.0' encoding='utf-8'?>
<mxfile host="app.diagrams.net">
  <diagram id="arch_simple" name="System Architecture (Simple)">
    <mxGraphModel dx="900" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="client" value="Web Browser&#10;(User)" style="shape=umlActor;whiteSpace=wrap;html=1;fontSize=13;align=center;fillColor=#DAE8FC;strokeColor=#1F6FB2;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="310.0" y="20" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="presentation" value="Presentation Layer&#10;Django Templates + Static Files (CSS/JS)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;align=center;verticalAlign=middle;fillColor=#FFE6CC;strokeColor=#D79B00;fontColor=#7A4A00;" vertex="1" parent="1">
          <mxGeometry x="260" y="130" width="380" height="70" as="geometry" />
        </mxCell>
        <mxCell id="auth" value="Authentication &amp;&#10;Authorization&#10;&#10;Login · Register ·&#10;Password Reset&#10;(security question)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;align=center;verticalAlign=middle;fillColor=#F8CECC;strokeColor=#B85450;fontColor=#7A2020;" vertex="1" parent="1">
          <mxGeometry x="20" y="250" width="190" height="130" as="geometry" />
